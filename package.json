{
	"name": "talaria",
	"version": "0.1.0",
	"description": "Obsidian plugin: triage note ideas into GitHub issues with a local LLM",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"install:vault": "npm run build && node scripts/install-vault.mjs"
	},
	"keywords": [],
	"author": "Sonar-Arts",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.21.5",
		"obsidian": "latest",
		"tslib": "^2.6.2",
		"typescript": "^5.4.5"
	}
}
